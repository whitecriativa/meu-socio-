# ============================================================
# SOCIO - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositorio.
# ============================================================

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# NUNCA expor no frontend - apenas backend/n8n
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# Evolution API (WhatsApp)
# ------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE_NAME=socio

# ------------------------------------------------------------
# Google Calendar
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ------------------------------------------------------------
# Stripe
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------
# n8n
# ------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=sua_api_key_n8n

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

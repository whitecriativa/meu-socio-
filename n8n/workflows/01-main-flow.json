    {
      "id": "parse-gpt",
      "name": "Interpretar GPT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300],
      "parameters": {
        "jsCode": "const content = $input.first().json.choices[0].message.content.trim();\nconst userId = $('Buscar usuário').first().json.id;\nconst phone = $('Extrair dados').first().json.remoteJid;\ntry {\n  const jsonMatch = content.match(/\\{[^{}]+\\}/);\n  if (jsonMatch) {\n    const parsed = JSON.parse(jsonMatch[0]);\n    if (parsed.intent === 'registrar_receita' || parsed.intent === 'registrar_despesa') {\n      return [{ json: { intent: parsed.intent, amount: parsed.amount, description: parsed.description, userId, phone } }];\n    }\n    if (parsed.intent === 'registrar_agendamento') {\n      return [{ json: { intent: parsed.intent, service: parsed.service, client_name: parsed.client_name, scheduled_at: parsed.scheduled_at, price: parsed.price || 0, userId, phone } }];\n    }\n    if (parsed.intent === 'definir_meta') {\n      return [{ json: { intent: parsed.intent, amount: parsed.amount, userId, phone } }];\n    }\n  }\n} catch(e) {}\nreturn [{ json: { intent: 'resposta', responseText: content, userId, phone } }];"
      }
    },

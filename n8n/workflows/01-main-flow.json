      "name": "Extrair dados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst data = body.data;\nconst key = data.key;\nconst remoteJid = key.remoteJid;\nlet phone = remoteJid.replace(/@.*$/, '');\nif (!phone.startsWith('55')) phone = '55' + phone;\nlet text = '';\nif (data.messageType === 'conversation') {\n  text = data.message?.conversation || '';\n} else if (data.messageType === 'extendedTextMessage') {\n  text = data.message?.extendedTextMessage?.text || '';\n}\nreturn [{ json: { phone, remoteJid, pushName: data.pushName || 'Amigo', text: text.trim(), instanceName: body.instance } }];"
      }
    },

  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
  "tags": [{"name": "socio"}, {"name": "whatsapp"}],
  "meta": {"instanceId": "socio-main"}

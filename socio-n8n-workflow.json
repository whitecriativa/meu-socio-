            {
              "name": "number",
              "value": "={{ $node['Webhook WhatsApp'].json.body.data.key.remoteJid }}"
            },
            {
              "name": "text",
              "value": "={{ JSON.parse($node['Detecta Intenção (GPT-4o-mini)'].json.choices[0].message.content).response }}"
            }
          ]
        },
        "options": {}
      },
      "id": "send-whatsapp",
      "name": "Envia Resposta WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
